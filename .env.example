# ============================================================================
# Hotel Siddhi Vinayak AI OS — environment template
# Copy to .env (never commit .env). All secrets are server-side only.
# ============================================================================

# --- Database (Supabase Postgres) ---
# Supabase → Project Settings → Database → Connection string (use the pooled
# "Transaction" URL for the app, the direct URL for migrations).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Stayflexi: BOOKING ENGINE API (groupId + key, issued by your CSM) ---
# Base host is fixed by Stayflexi; override only if they tell you to.
STAYFLEXI_BE_BASE_URL="https://api.stayflexi.com"
STAYFLEXI_GROUP_ID=""          # your group id (e.g. 23925)
STAYFLEXI_BE_API_KEY=""        # X-SF-API-KEY for the Booking Engine API

# --- Stayflexi: CHANNEL MANAGER API (pmsId + key, issued by admin@stayflexi) ---
# NOTE: docs are ambiguous — prose says https://stayflexi.com, examples show
# http://beta.stayflexi.com. Confirm the correct production host with Stayflexi.
STAYFLEXI_CM_BASE_URL="https://stayflexi.com"
STAYFLEXI_PMS_ID=""            # your pms id
STAYFLEXI_CM_API_KEY=""        # X-SF-API-KEY for the Channel Manager API

# The Stayflexi hotelId for Hotel Siddhi Vinayak (from grouphotels). The public
# booking engine uses hotel_id=29355; confirm this matches the API hotelId.
STAYFLEXI_HOTEL_ID=""

# Shared secret you generate; Stayflexi posts webhooks to /api/webhooks/stayflexi.
# (Stayflexi does NOT sign webhooks, so we gate on this secret in the URL/query.)
STAYFLEXI_WEBHOOK_SECRET=""

# --- Google (Analytics AI / SEO AI) — service-account JSON, base64-encoded ---
# Numeric GA4 property id (GA4 Admin -> Property Settings). Requires the
# "Google Analytics Data API" to be ENABLED on the Cloud project.
GA4_PROPERTY_ID=""
# Search Console PROPERTY id. DOMAIN property -> "sc-domain:example.com";
# URL-prefix property -> "https://example.com/". Run `npm run google:verify`
# to discover the exact value the service account can read.
GSC_SITE_URL="sc-domain:hotelsiddhi-vinayak.com"
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=""

# Public website the Website AI monitor probes (a real URL — separate from the
# GSC property id above).
PUBLIC_SITE_URL="https://hotelsiddhi-vinayak.com"

# Optional: PageSpeed Insights API key. Core Web Vitals work without it but the
# anonymous quota is small and returns 429 under load; a key makes CWV reliable.
PAGESPEED_API_KEY=""

# --- YouTube AI: official Google APIs via OAuth (no API key) ---
# Web-application OAuth client on the Cloud project. The refresh token must be
# minted with scopes: youtube.readonly + yt-analytics.readonly. Requires both
# "YouTube Data API v3" and "YouTube Analytics API" ENABLED on the project.
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
YOUTUBE_REFRESH_TOKEN=""

# --- Facebook + Instagram AI: official Meta Graph API (read-only) ---
# One long-lived user/system-user token covers both. Required scopes:
# pages_show_list, pages_read_engagement, read_insights, pages_read_user_content,
# instagram_basic, instagram_manage_insights, business_management.
# FACEBOOK_ACCESS_TOKEN (page token) is optional — derived at runtime if unset.
META_ACCESS_TOKEN=""
FACEBOOK_PAGE_ID=""          # e.g. 255227581001102
INSTAGRAM_BUSINESS_ID=""     # e.g. 17841455022004658
FACEBOOK_ACCESS_TOKEN=""

# --- Google Ads AI: official Google Ads API (read-only, via MCC) ---
# Developer token from the MCC's API Center; OAuth client + refresh token with
# scope https://www.googleapis.com/auth/adwords. IDs are digits only, no dashes.
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""
GOOGLE_ADS_REFRESH_TOKEN=""
GOOGLE_ADS_LOGIN_CUSTOMER_ID=""   # MCC, e.g. 4785489942
GOOGLE_ADS_CUSTOMER_ID=""         # client account, e.g. 7225725435

# --- App ---
NODE_ENV="development"
LOG_LEVEL="info"             # debug | info | warn | error
